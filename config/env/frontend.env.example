# Frontend-safe local backend environment.
# Copy to project root as .env only on the frontend developer machine.
# This template intentionally disables Telegram long polling.

# === DATABASE CONFIG ===
POSTGRES_URL=jdbc:postgresql://localhost:5434/aether
POSTGRES_DB=aether
POSTGRES_USER=oracle
POSTGRES_PASSWORD=astor_unlock

# === LIQUIBASE CONFIG ===
SPRING_LIQUIBASE_CHANGE_LOG=classpath:db/changelog/changelog-master.yaml

# === REDIS CONFIG ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=astor_unlock
FSM_REDIS_TTL_SECONDS=900

# === MONGO DOCUMENT/MEDIA METADATA ===
MONGO_DB=aether
MONGO_PORT=27017
MONGO_USER=oracle
MONGO_PASSWORD=astor_unlock
MONGODB_URI=mongodb://oracle:astor_unlock@localhost:27017/aether?authSource=admin

# === KAFKA ===
KAFKA_PORT=9092

# === MINIO / S3 ===
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=astor
S3_SECRET_KEY=astor_minio_password
S3_BUCKET_MEDIA=astor-media
S3_BUCKET_DOCUMENTS=astor-documents
S3_PORT=9000
S3_CONSOLE_PORT=9001

# === TELEGRAM: DISABLED FOR FRONTEND WORK ===
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_USERNAME=astor_butler_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_CLIENT_ID=
TELEGRAM_REDIRECT_URI=http://localhost:8088/auth/telegram/callback

# === AI / INTEGRATIONS ===
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_OLLAMA_MODEL=qwen2.5:1.5b
YANDEX_FOLDER_ID=
YANDEX_IAM_TOKEN=
YANDEX_AGENT_ENDPOINT=

# === MONITORING ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# === SPRING ===
SERVER_PORT=8088
SPRING_PROFILES_ACTIVE=local

# === LOGGING & SECURITY ===
JWT_SECRET=frontend-local-dev-only
LOG_LEVEL=INFO
